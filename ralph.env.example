# Copy to ralph.env (gitignored) and edit. Sourced by ralph.sh.

# Absolute path to the target repo the loop works on. For the self-hosting setup this is ralph-alpha itself.
REPO="$HOME/projects/ralph-alpha"

# spec | implement
#   spec      = draft specs for the next backlog item, commit to main, stop. Zero risk.
#   implement = implement the next APPROVED spec on a branch, run tests, open a PR. Never merges.
MODE="spec"

# Model for the loop. Sonnet recommended (cost). Set to opus only for a project that demands it.
MODEL="claude-sonnet-4-6"

# Circuit breakers
MAX_ITERS=1                 # iterations per night. Start at 1. Grow to ~4-6 once trusted.
MAX_CONSEC_FAILURES=2       # stop the night after this many back-to-back failed iterations
TIME_BUDGET_SECONDS=10800   # hard wall-clock cap (3h)

# Command that proves the repo is in a good state after an iteration (the "back-pressure").
# Must exit 0 on success. For ralph-alpha itself, shellcheck + a smoke run of ralph.sh --dry-run.
TEST_CMD='./ralph.sh --self-test'

# Git remote name to push implement-mode branches to. Branch is never merged by the loop.
REMOTE="origin"

# Default branch. Never pushed to by implement-mode (spec docs excepted).
MAIN_BRANCH="main"
